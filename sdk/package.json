{
    "name": "@iota/iota-names-sdk",
    "author": "IOTA Foundation <info@iota.org>",
    "description": "IOTA-Names SDK",
    "version": "0.7.2",
    "license": "Apache-2.0",
    "private": false,
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/cjs/index.d.ts",
    "keywords": [
        "IOTA",
        "IOTA-Names"
    ],
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "CHANGELOG.md",
        "dist",
        "src"
    ],
    "scripts": {
        "clean": "rm -rf tsconfig.tsbuildinfo ./dist",
        "build": "build-package",
        "prepublishOnly": "pnpm build",
        "prettier:check": "prettier -c --ignore-unknown .",
        "prettier:fix": "prettier -w --ignore-unknown .",
        "eslint:check": "eslint --max-warnings=0 .",
        "eslint:fix": "pnpm run eslint:check --fix",
        "lint": "pnpm run eslint:check && pnpm run prettier:check",
        "lint:fix": "pnpm run eslint:fix && pnpm run prettier:fix",
        "test:e2e": "vitest run",
        "run:example": "tsx"
    },
    "engines": {
        "node": ">=16"
    },
    "dependencies": {
        "@iota/iota-sdk": "^1.2.0",
        "axios": "^0.24.0",
        "axios-retry": "^3.9.1"
    },
    "devDependencies": {
        "@iota/build-scripts": "workspace:^",
        "@iota/graphql-transport": "^0.6.0",
        "@types/tmp": "^0.2.6",
        "ts-retry-promise": "^0.8.1",
        "tsx": "^4.19.3",
        "typescript": "^5.7.2",
        "vite": "^6.0.7",
        "vitest": "^2.1.8"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iotaledger/iota-names.git"
    },
    "bugs": {
        "url": "https://github.com/iotaledger/iota-names/issues"
    }
}
