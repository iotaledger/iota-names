{
    "ui": "tui",
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "lint": {},
        "lint:fix": {
            "dependsOn": ["^build"]
        },
        "prettier:fix": {
            "cache": false
        },
        "test": {
            "dependsOn": ["^build", "build"],
            "outputs": ["coverage/**"]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["build/**", "dist/**", ".next/**", "!.next/cache/**"],
            "passThroughEnv": ["SENTRY_AUTH_TOKEN", "BUILD_ENV"]
        }
    }
}
